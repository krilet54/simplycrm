{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd wacrm && npm ci",
  "buildCommand": "cd wacrm && npm run build",
  "devCommand": "cd wacrm && npm run dev",
  "outputDirectory": "wacrm/.next",
  "crons": [
    {
      "path": "/api/cron/trial-expiry",
      "schedule": "0 8 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

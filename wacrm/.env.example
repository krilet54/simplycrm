# =================================================================
# ENVIRONMENT VARIABLES - DEVELOPMENT REFERENCE ONLY
# =================================================================
# DO NOT commit real values - this file is for reference only
# For production on Vercel, set variables in: 
# Vercel Dashboard > Project Settings > Environment Variables

# DATABASE (SUPABASE) =============================================
# WARNING: Sensitive - Never commit real values
# Get from Supabase > Project Settings > Database
# Use pooled connection for serverless runtime (Vercel/Lambda)
DATABASE_POOLER_URL="postgresql://postgres:PASSWORD@db.PROJECT-REF.supabase.co:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
# Keep DATABASE_URL for local tools/migrations if needed
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres?sslmode=require"

# SUPABASE AUTHENTICATION =========================================
# NEXT_PUBLIC variables are safe (frontend accessible)
# Service role key is SENSITIVE - admin access, never expose
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# NEXTAUTH CONFIGURATION ==========================================
# Generate secrets: openssl rand -base64 32
# WARNING: Sensitive - Never share these values
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="GENERATE_WITH_OPENSSL_RAND"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# STRIPE PAYMENT PROCESSING =======================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# RAZORPAY PAYMENT PROCESSING =====================================
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_SECRET_KEY="RAZORPAY_SECRET_..."

# EMAIL SERVICE (RESEND) ==========================================
# API key from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@crm.com"

# CRON JOBS =========================================================
# Secret for protecting scheduled API endpoints
# Generate: openssl rand -base64 32
CRON_SECRET="GENERATE_WITH_OPENSSL_RAND"

# RATE LIMITING (UPSTASH REDIS) ===================================
# Optional: Free tier at https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# WHATSAPP INTEGRATION (OPTIONAL) =================================
# Only needed if using WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN="WEBHOOK_TOKEN"
WHATSAPP_APP_SECRET="APP_SECRET"
WHATSAPP_PHONE_NUMBER_ID="PHONE_ID"
WHATSAPP_ACCESS_TOKEN="ACCESS_TOKEN"

# NODE ENVIRONMENT ================================================
NODE_ENV="development"
# ─── Database ───────────────────────────────────────────────────────────────
# Get from Supabase > Project Settings > Database > Connection string
DATABASE_POOLER_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# ─── Supabase Auth ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Meta / WhatsApp Cloud API ───────────────────────────────────────────────
# Create app at developers.facebook.com > WhatsApp > API Setup
WHATSAPP_VERIFY_TOKEN="choose_any_random_string_here"
WHATSAPP_APP_SECRET="from_meta_app_dashboard"

# Per-workspace tokens are stored in the DB.
# The system phone number ID is stored per workspace too.
# For the default/first workspace during dev:
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"
WHATSAPP_ACCESS_TOKEN="your_long_lived_access_token"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"

# Your verified domain email (e.g., noreply@yourdomain.com or noreply@wacrm.com)
# For development, you can use any email, but in production use a verified domain
RESEND_FROM_EMAIL="noreply@wacrm.com"

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# ─── Paystack ───────────────────────────────────────────────────────────────
# Get from Paystack Dashboard > Settings > API Keys & Webhooks
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
PAYSTACK_WEBHOOK_SECRET="whsec_..." # For webhook signature verification

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate_with: openssl rand -base64 32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
# Secret key for protecting scheduled API endpoints (e.g., daily digest emails)
CRON_SECRET="generate_with: openssl rand -base64 32"

# ─── Rate Limiting (Upstash Redis) ───────────────────────────────────────────
# Get free tier at https://console.upstash.com/
# Create a Redis database and copy the REST URL and Token
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

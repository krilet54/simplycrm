// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Workspaces ──────────────────────────────────────────────────────────────
model Workspace {
  id                    String   @id @default(uuid())
  businessName          String
  stripeCustomerId      String?
  stripePriceId         String?
  stripeSubscriptionId  String?
  plan                  Plan     @default(STARTER)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Trial system
  trialEndsAt           DateTime?  // Set on workspace creation (now + 14 days)
  trialExpired          Boolean    @default(false)

  // Onboarding
  onboardingCompleted   Boolean  @default(false)

  // Invoice branding
  invoiceLogo           String?  // URL to logo image
  invoicePrimaryColor   String?  @default("#22c55e") // Primary color for invoices
  invoiceFooterText     String?  // Custom footer text for invoices
  invoiceBusinessAddress String? // Business address shown on invoices
  invoiceBusinessPhone  String?  // Business phone shown on invoices
  invoiceBusinessEmail  String?  // Business email shown on invoices

  users         User[]
  contacts      Contact[]
  quickReplies  QuickReply[]
  kanbanStages  KanbanStage[]
  tags          Tag[]
  invoices      Invoice[]
  metaOAuthToken MetaOAuthToken?
  activities    Activity[]
  tasks         Task[]
  followUps     FollowUp[]
  emails        Email[]
  recurringInvoices RecurringInvoice[]
  invites       Invite[]
  notifications Notification[]

  @@map("workspaces")
}

enum Plan {
  STARTER
  PRO
  TRIAL
}

enum ContactSource {
  WHATSAPP
  WALK_IN
  PHONE_CALL
  REFERRAL
  SOCIAL_MEDIA
  EVENT
  OTHER
}

// ─── Users (Agents) ──────────────────────────────────────────────────────────
model User {
  id          String   @id @default(uuid())
  workspaceId String
  supabaseId  String   @unique // Supabase Auth user ID
  name        String
  email       String
  phoneNumber String?  // Agent's phone number (added during onboarding)
  role        AgentRole @default(AGENT)
  avatarUrl   String?
  isOnline    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace              Workspace @relation(fields: [workspaceId], references: [id])
  notes                  Note[]
  activities             Activity[]  // Activities created by this user
  createdTasks           Task[] @relation("CreatedTasks")
  assignedTasks          Task[] @relation("AssignedTasks")
  followUps              FollowUp[]
  assignedContacts       Contact[] @relation("AssignedContacts")  // Contacts assigned to this user
  assignedByContacts     Contact[] @relation("AssignedByContacts")  // Contacts this user assigned
  createdContacts        Contact[] @relation("CreatedContacts")  // Contacts this user added
  notifications          Notification[]  // Notifications for this user

  @@map("users")
}

enum AgentRole {
  OWNER
  ADMIN
  AGENT
}

// ─── Assignment Status ────────────────────────────────────────────────────────
enum AssignmentStatus {
  ACTIVE
  COMPLETED
}

// ─── Confidence/Intent Levels ─────────────────────────────────────────────────
enum ConfidenceLevel {
  HIGH_INTENT          // Ready to buy
  EXPLORATORY          // Just looking/early stage
  NEGOTIATING          // In active discussion
  DEMO_SCHEDULED       // Demo booked
}

// ─── Contacts ────────────────────────────────────────────────────────────────
model Contact {
  id             String            @id @default(uuid())
  workspaceId    String
  phoneNumber    String
  name           String?
  email          String?
  avatarUrl      String?
  kanbanStageId  String?
  isBlocked      Boolean           @default(false)
  source         ContactSource     @default(WHATSAPP)
  sourceNote     String?
  interest       String?
  estimatedValue Float?
  confidenceLevel ConfidenceLevel?  // Manually set - shows intent badge on Kanban
  lastActivityAt DateTime?
  
  // ─── Delegation ───────────────────────────────────────────────────────────
  assignedToId   String?           // Current assignee (agent/admin)
  assignedById   String?           // Who assigned it (owner/admin)
  delegationNote String?           // Note contextualizing the work
  assignmentStatus AssignmentStatus? @default(ACTIVE)
  assignedAt     DateTime?
  completedAt    DateTime?

  // ─── Tracking ─────────────────────────────────────────────────────────────
  createdById    String?           // Who added/created the contact
  
  deletedAt      DateTime?         // Soft-delete
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id])
  kanbanStage  KanbanStage? @relation(fields: [kanbanStageId], references: [id])
  assignedTo   User?        @relation("AssignedContacts", fields: [assignedToId], references: [id])
  assignedBy   User?        @relation("AssignedByContacts", fields: [assignedById], references: [id])
  createdBy    User?        @relation("CreatedContacts", fields: [createdById], references: [id])
  notes        Note[]
  contactTags  ContactTag[]
  invoices     Invoice[]
  activities   Activity[]
  tasks        Task[]
  followUps    FollowUp[]
  emails       Email[]
  recurringInvoices RecurringInvoice[]

  @@unique([workspaceId, phoneNumber])
  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, lastActivityAt])
  @@index([workspaceId, assignedToId])
  @@index([workspaceId, assignedToId, assignmentStatus])
  @@map("contacts")
}

// ─── Activity Timeline ─────────────────────────────────────────────────────────
enum ActivityType {
  NOTE
  CALL
  MEETING
  EMAIL
  WHATSAPP
  INVOICE_SENT
  STAGE_CHANGE
  CONTACT_ADDED
  OTHER
}

model Activity {
  id          String       @id @default(uuid())
  workspaceId String
  contactId   String
  authorId    String?      // which agent logged this
  type        ActivityType
  content     String       // what was discussed/happened
  timestamp   DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  contact   Contact   @relation(fields: [contactId], references: [id])
  author    User?     @relation(fields: [authorId], references: [id])

  @@index([contactId, timestamp])
  @@index([workspaceId, timestamp])
  @@map("activities")
}

// ─── Notes (private, not sent to customer) ───────────────────────────────────
model Note {
  id        String   @id @default(uuid())
  contactId String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])

  @@map("notes")
}

// ─── Kanban Stages ───────────────────────────────────────────────────────────
model KanbanStage {
  id          String  @id @default(uuid())
  workspaceId String
  name        String
  color       String  @default("#2e8535")
  position    Int
  isDefault   Boolean @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  contacts  Contact[]

  @@map("kanban_stages")
}

// ─── Tags ────────────────────────────────────────────────────────────────────
model Tag {
  id          String @id @default(uuid())
  workspaceId String
  name        String
  color       String @default("#6366f1")

  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  contactTags ContactTag[]

  @@unique([workspaceId, name])
  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([contactId, tagId])
  @@map("contact_tags")
}

// ─── Quick Replies ────────────────────────────────────────────────────────────
model QuickReply {
  id          String @id @default(uuid())
  workspaceId String
  shortcut    String // e.g. "/hello"
  title       String
  content     String

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, shortcut])
  @@map("quick_replies")
}

// ─── Invoices ─────────────────────────────────────────────────────────────
enum InvoiceStatus {
  DRAFT
  SENT
  RECEIVED
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String          @id @default(uuid())
  workspaceId   String
  contactId     String
  invoiceNumber String          // e.g. "INV-001"
  description   String?         // e.g. "Website Design Services"
  amount        Float           // Total amount
  status        InvoiceStatus   @default(DRAFT)
  dueDate       DateTime?
  sentAt        DateTime?
  paidAt        DateTime?
  notes         String?         // Additional notes for the invoice
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  workspace     Workspace       @relation(fields: [workspaceId], references: [id])
  contact       Contact         @relation(fields: [contactId], references: [id])
  items         InvoiceItem[]

  @@unique([workspaceId, invoiceNumber])
  @@index([contactId])
  @@index([workspaceId, status])
  @@map("invoices")
}

model InvoiceItem {
  id        String   @id @default(uuid())
  invoiceId String
  description String
  quantity  Float
  unitPrice Float
  total     Float   // quantity * unitPrice
  createdAt DateTime @default(now())

  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─── Recurring Invoices ───────────────────────────────────────────────────────
enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringInvoice {
  id              String             @id @default(uuid())
  workspaceId     String
  contactId       String
  title           String             // e.g. "Monthly Cleaning Service"
  frequency       RecurringFrequency @default(MONTHLY)
  amount          Float              // Fixed amount per occurrence
  isActive        Boolean            @default(true)
  nextInvoiceDate DateTime           // When the next invoice should be generated
  lastInvoiceDate DateTime?          // When the last invoice was generated
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  workspace       Workspace          @relation(fields: [workspaceId], references: [id])
  contact         Contact            @relation(fields: [contactId], references: [id])
  items           RecurringInvoiceItem[]

  @@index([workspaceId])
  @@index([contactId])
  @@index([isActive, nextInvoiceDate])
  @@map("recurring_invoices")
}

model RecurringInvoiceItem {
  id                 String           @id @default(uuid())
  recurringInvoiceId String
  description        String
  quantity           Float
  unitPrice          Float

  recurringInvoice   RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)

  @@index([recurringInvoiceId])
  @@map("recurring_invoice_items")
}

// ─── Meta OAuth Tokens ────────────────────────────────────────────────────────
model MetaOAuthToken {
  id                String   @id @default(uuid())
  workspaceId       String   @unique
  accessToken       String   // Long-lived token (plaintext for now, encrypt in prod)
  phoneNumberId     String   // Meta Phone Number ID
  businessAccountId String?  // FOR FUTURE: WhatsApp Business Account ID
  expiresAt         DateTime?
  refreshToken      String?  // FOR FUTURE: Token refresh flow
  connectedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("meta_oauth_tokens")
}

// ─── Tasks & Reminders ────────────────────────────────────────────────────────
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskType {
  MANUAL
  AUTO_PAYMENT_DUE
  AUTO_NO_REPLY_24H
  AUTO_INVOICE_SENT
  AUTO_INVOICE_OVERDUE
}

model Task {
  id            String       @id @default(uuid())
  workspaceId   String
  contactId     String?
  createdById   String       // User who created this task
  assignedToId  String?      // Which agent it's assigned to
  title         String
  description   String?
  dueDate       DateTime?
  status        TaskStatus   @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  type          TaskType     @default(MANUAL)
  reminderSent  Boolean      @default(false)
  completedAt   DateTime?
  snoozedUntil  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  contact   Contact?  @relation(fields: [contactId], references: [id])
  createdBy User      @relation("CreatedTasks", fields: [createdById], references: [id])
  assignedTo User?    @relation("AssignedTasks", fields: [assignedToId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, status, dueDate])
  @@index([contactId])
  @@index([assignedToId])
  @@map("tasks")
}

// ─── Follow-Ups ───────────────────────────────────────────────────────────────
model FollowUp {
  id          String   @id @default(uuid())
  workspaceId String
  contactId   String
  createdById String
  note        String?  // what to follow up about
  dueDate     DateTime
  isDone      Boolean  @default(false)
  doneAt      DateTime?
  createdAt   DateTime @default(now())

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  contact    Contact   @relation(fields: [contactId], references: [id])
  createdBy  User      @relation(fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, isDone])
  @@index([workspaceId, dueDate])
  @@index([contactId])
  @@map("follow_ups")
}

// ─── Email Communication ──────────────────────────────────────────────────────
enum EmailStatus {
  DRAFT
  SENT
  BOUNCED
  FAILED
}

model Email {
  id          String      @id @default(uuid())
  workspaceId String
  contactId   String
  from        String      // Workspace admin email
  to          String      // Contact email
  subject     String
  body        String
  status      EmailStatus @default(DRAFT)
  sentAt      DateTime?
  openedAt    DateTime?   // FOR FUTURE: Tracking pixel
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  contact   Contact   @relation(fields: [contactId], references: [id])

  @@index([contactId, sentAt])
  @@index([workspaceId, status])
  @@map("emails")
}

// ─── Notifications ────────────────────────────────────────────────────────────
enum NotificationType {
  CONTACT_ASSIGNED
  TASK_ASSIGNED
  FOLLOWUP_ASSIGNED
  FOLLOWUP_DUE
  TASK_DUE
  CONTACT_CREATED
}

model Notification {
  id            String           @id @default(uuid())
  workspaceId   String
  userId        String           // Recipient of notification
  type          NotificationType
  title         String
  message       String
  relatedId     String?          // ID of contact/task/followup
  relatedType   String?          // "CONTACT", "TASK", "FOLLOWUP"
  isRead        Boolean          @default(false)
  readAt        DateTime?
  createdAt     DateTime         @default(now())
  
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([workspaceId, userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── User Relations Extensions ────────────────────────────────────────────────
// User model extended to include activities and tasks they created
// (already defined above, just adding to User relations)

// ─── Team Invitations ──────────────────────────────────────────────────────────
model Invite {
  id            String   @id @default(cuid())
  workspaceId   String
  email         String
  role          String   @default("AGENT")
  status        String   @default("PENDING")  // PENDING, ACCEPTED, EXPIRED
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([status])
  @@map("invites")
}

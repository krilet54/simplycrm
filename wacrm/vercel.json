{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "crons": [
    {
      "path": "/api/cron/trial-expiry",
      "schedule": "0 8 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

